{
  "name": "app-environment-practice",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps-backend",
    "apps-frontend"
  ],
  "scripts": {
    "start": "node apps-backend/dist/main",
    "start:prod": "node apps-backend/dist/main",
    "start:backend": "node apps-backend/dist/main",
    "start:frontend": "npm run dev -w apps-frontend",
    "install:all": "npm install --prefix apps-backend && npm install --prefix apps-frontend --legacy-peer-deps",
    "test:int:backend": "npm run test:int:cov --prefix apps-backend",
    "test:int:frontend": "npm run test:int:cov --prefix apps-frontend",
    "test:int": "npm run test:int:backend && npm run test:int:frontend"
  }
}
